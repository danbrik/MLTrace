# Backend runtime config.
#
# SQLite is the default for local single-user deployments. Keep .mltrace/
# persistent because it stores the database, scheduler settings, logs, and run
# artifacts.
DATABASE_URL=sqlite:///./.mltrace/mltrace.db

# Add every frontend origin that may call the API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Default queued training/testing worker slot count before the Scheduler UI
# writes .mltrace/scheduler_settings.json. GPU detection clamps this at runtime.
MAX_CONCURRENT_TRAININGS=4
